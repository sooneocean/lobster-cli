{
  "name": "@dexter/exoframe-core",
  "version": "0.1.0",
  "description": "ExoFrame core – task pipeline engine, independent of any host platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
