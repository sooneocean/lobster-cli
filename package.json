{
  "name": "lobster-cli",
  "version": "0.1.0",
  "description": "LangGraph-focused CLI toolkit",
  "bin": {
    "lobster-cli": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "eslint .",
    "test": "vitest run"
