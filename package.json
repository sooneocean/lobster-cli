    "chokidar": "^3.6.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1",
    "p-limit": "^6.1.0",
    "pg": "^8.13.1",
    "picocolors": "^1.1.0",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "eslint": "^9.19.0",
    "tsx": "^4.19.2",
    "tsup": "^8.2.4",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
